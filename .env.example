PORT=3006
NODE_ENV=development

# Postgres
# Prefer `DATABASE_URL`, fallback to PG* variables.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/goalden_notification
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=goalden_notification
PGUSER=postgres
PGPASSWORD=postgres

# Internal service auth (JWT service -> /internal/*)
SERVICE_JWT_SECRET=replace-with-service-jwt-secret

# SMTP provider
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=no-reply@goalden.local
