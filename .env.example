PORT=3006
NODE_ENV=development

# MongoDB (base dediee goalden_notification)
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/goalden_notification?retryWrites=true&w=majority

# JWT inter-services : meme valeur que SERVICE_JWT_SECRET de auth-service
SERVICE_JWT_SECRET=

# SMTP obligatoire (PRD / guide — ex. Mailtrap sandbox gratuit)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@goalden.local
